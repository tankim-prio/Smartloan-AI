      `}</style>

      <section className="page-header">
        <div>
          <h1 className="page-title">SmartLoan AI — Application Workflow</h1>
          <p className="page-subtitle">
            Correct flow: scan photo → create PDF → download PDF → upload PDF in Apply for Loan → extract text → extract fields → send review or predict.
          </p>
        </div>

        <div className="app-id-card">
          <label>
            Application ID
            <input
              value={applicationId}
              onChange={(event) => setApplicationId(event.target.value)}
            />
          </label>
        </div>
      </section>

      {(successMessage || errorMessage) && (
        <section className="message-grid">
          {successMessage && <div className="success-msg">{successMessage}</div>}
          {errorMessage && <div className="error-msg">{errorMessage}</div>}
        </section>
      )}

      <section className="dashboard-grid">
        <section className="card wide-card">
          <div className="card-head">
            <div>
              <span className="step-pill">Step 03</span>
              <h2>Scan Photo</h2>
              <p>Upload applicant photo or use Scan Photo. On mobile, the scan button will prefer the front camera.</p>
            </div>
            <span className={photoConfirmed ? "status-pill done" : "status-pill"}>
              {photoConfirmed ? "Confirmed" : "Pending"}
            </span>
          </div>

          <div className="upload-box">
            <span className="upload-title">Applicant Photo</span>

            <input
              ref={photoUploadRef}
              type="file"
              accept="image/*"
              onChange={(event) => {
                const file = event.target.files?.[0];
                if (file) {
                  setPhotoFile(file);
                  setPhotoConfirmed(false);
                  success("Photo selected. Click Confirm Step 3.");
                }
              }}
            />

            <input
              ref={photoCameraRef}
              hidden
              type="file"
              accept="image/*"
              capture="user"
              onChange={(event) => {
                const file = event.target.files?.[0];
                if (file) {
                  setPhotoFile(file);
                  setPhotoConfirmed(false);
                  success("Camera photo captured. Click Confirm Step 3.");
                }
              }}
            />

            {photoFile && <p className="file-ready">Photo ready: {photoFile.name}</p>}

            <div className="btn-row">
              <button className="btn soft" type="button" onClick={() => photoUploadRef.current?.click()}>
                Choose Photo
              </button>

              <button className="btn dark" type="button" onClick={() => photoCameraRef.current?.click()}>
                Scan Photo
              </button>

              <button
                className="btn primary"
                type="button"
                disabled={!photoFile || loading === "photo"}
                onClick={handleConfirmPhoto}
              >
                {loading === "photo" ? "Confirming..." : "Confirm Step 3"}
              </button>
            </div>
          </div>
        </section>

        <section className="card">
          <div className="card-head">
            <div>
              <h2>Create PDF</h2>
              <p>After Step 1, Step 2, and Step 3, create the system-generated application PDF.</p>
            </div>
            <span className={generatedPdfReady ? "status-pill done" : "status-pill"}>
              {generatedPdfReady ? "Ready" : "Pending"}
            </span>
          </div>

          <div className="btn-row">
            <button
              className="btn primary"
              type="button"
              disabled={!photoConfirmed || loading === "pdf"}
              onClick={handleCreatePdf}
            >
              {loading === "pdf" ? "Creating PDF..." : "Create PDF"}
            </button>

            {generatedPdfReady && generatedPdfUrl && (
              <a className="btn green" href={generatedPdfUrl} download={generatedPdfName}>
                Download PDF
              </a>
            )}
          </div>

          {generatedPdfReady && (
            <p className="good-text">
              Generated PDF is ready. Download it, then upload it in Apply for Loan.
            </p>
          )}

          {!generatedPdfReady && (
            <p>No extraction button here. Extract Text belongs inside Apply for Loan after PDF upload.</p>
          )}
        </section>

        <section className="card">
          <div className="card-head">
            <div>
              <h2>Apply for Loan</h2>
              <p>Upload the generated PDF here. Then confirm upload and extract text.</p>
            </div>
            <span className={loanPdfConfirmed ? "status-pill done" : "status-pill"}>
              {loanPdfConfirmed ? "Uploaded" : "Pending"}
            </span>
          </div>

          <div className="upload-box">
            <span className="upload-title">Loan Application Document</span>

            <input
              type="file"
              accept="application/pdf"
              onChange={(event) => {
                const file = event.target.files?.[0];
                if (file) {
                  setLoanPdfFile(file);
                  resetExtractionFlow();
                  success("Loan PDF selected. Click Confirm Loan Application Upload.");
                }
              }}
            />

            {loanPdfFile && <p className="file-ready">PDF ready: {loanPdfFile.name}</p>}

            <div className="btn-row">
              <button
                className="btn soft"
                type="button"
                disabled={!loanPdfFile || loading === "loan-upload"}
                onClick={handleConfirmLoanUpload}
              >
                {loading === "loan-upload" ? "Uploading..." : "Confirm Loan Application Upload"}
              </button>

              {loanPdfConfirmed && (
                <button
                  className="btn primary"
                  type="button"
                  disabled={loading === "extract-text"}
                  onClick={handleExtractText}
                >
                  {loading === "extract-text" ? "Extracting Text..." : "Extract Text"}
                </button>
              )}
            </div>
          </div>
        </section>

        <section className="card wide-card">
          <div className="card-head">
            <div>
              <h2>Readable Extracted Text</h2>
              <p>This text view should include applicant data, scanned photo reference, salary certificate reference, and uploaded identity document reference from the PDF.</p>
            </div>
            <span className={textExtracted ? "status-pill done" : "status-pill"}>
              {textExtracted ? "Extracted" : "Waiting"}
            </span>
          </div>

          {textExtracted ? (
            <>
              <pre className="text-view">{extractedText}</pre>

              <div className="btn-row">
                <button
                  className="btn primary"
                  type="button"
                  disabled={loading === "extract-fields"}
                  onClick={handleExtractFields}
                >
                  {loading === "extract-fields" ? "Extracting Fields..." : "Extract Fields"}
                </button>
              </div>
            </>
          ) : (
            <p>No text yet. Upload generated PDF in Apply for Loan, confirm upload, then click Extract Text.</p>
          )}
        </section>

        <section className="card">
          <div className="card-head">
            <div>
              <h2>Extracted Fields</h2>
              <p>After Extract Fields, final action buttons will appear here.</p>
            </div>
            <span className={fieldsExtracted ? "status-pill done" : "status-pill"}>
              {fieldsExtracted ? "Ready" : "Waiting"}
            </span>
          </div>

          {fieldsExtracted && extractedFields ? (
            <>
              <div className="field-table">
                {Object.entries(extractedFields).map(([key, value]) => (
                  <div className="field-row" key={key}>
                    <strong>{key.replaceAll("_", " ")}</strong>
                    <span>{value === null || value === undefined ? "-" : String(value)}</span>
                  </div>
                ))}
              </div>

              <div className="btn-row">
                <button
                  className="btn green"
                  type="button"
                  disabled={loading === "review"}
                  onClick={handleSendReview}
                >
                  {loading === "review" ? "Sending..." : "Send Review"}
                </button>

                <button
                  className="btn primary"
                  type="button"
                  disabled={loading === "predict"}
                  onClick={handlePredict}
                >
                  {loading === "predict" ? "Predicting..." : "Predict"}
                </button>
              </div>
            </>
          ) : (
            <p>No fields extracted yet.</p>
          )}
        </section>

        <section className="card">
          <div className="card-head">
            <div>
              <h2>Prediction Result</h2>
              <p>Prediction appears only after extracted fields are ready.</p>
            </div>
          </div>

          {predictionResult ? (
            <div className="prediction-box">
              <pre>{JSON.stringify(predictionResult, null, 2)}</pre>
            </div>
          ) : (
            <p>No prediction yet.</p>
          )}
        </section>

        <section className="card">
          <h2>Uploaded Documents</h2>

          <div className="document-list" style={{ marginTop: 14 }}>
            {uploadedDocuments.length > 0 ? (
              uploadedDocuments.map((doc: any, index) => (
                <div className="list-item" key={doc.id || index}>
                  <div>
                    <strong>#{doc.id || index + 1} — {doc.document_type || doc.type || doc.title || "document"}</strong>
                    <p>{doc.filename || doc.name || doc.file_name || "Uploaded file"}</p>
                    <p>{doc.created_at || doc.uploaded_at || ""}</p>
                  </div>
                  <span className="status-pill done">{doc.status || "Approved"}</span>
                </div>
              ))
            ) : (
              <p>No uploaded documents loaded yet.</p>
            )}
          </div>
        </section>

        <section className="card">
          <h2>My Recent Applications</h2>

          <div className="application-list" style={{ marginTop: 14 }}>
            {recentApplications.length > 0 ? (
              recentApplications.slice(0, 5).map((app: any, index) => (
                <div className="list-item" key={app.id || index}>
                  <div>
                    <strong>#{app.id || app.application_id || index + 1} — {app.applicant_name || app.name || "Applicant"}</strong>
                    <p>{app.status || "Draft"}</p>
                  </div>

                  <button className="btn soft" type="button" onClick={() => useApplication(app)}>
                    Use
                  </button>
                </div>
              ))
            ) : (
              <p>No recent applications loaded yet.</p>
            )}
          </div>
        </section>

        <section className="card wide-card">
          <h2>Workflow Progress</h2>

          <div className="flow-bar">
            <span className={photoFile ? "flow-chip active" : "flow-chip"}>Photo selected/scanned</span>
            <span className={photoConfirmed ? "flow-chip active" : "flow-chip"}>Step 3 confirmed</span>
            <span className={generatedPdfReady ? "flow-chip active" : "flow-chip"}>PDF generated</span>
            <span className={loanPdfFile ? "flow-chip active" : "flow-chip"}>Loan PDF selected</span>
            <span className={loanPdfConfirmed ? "flow-chip active" : "flow-chip"}>Loan PDF uploaded</span>
            <span className={textExtracted ? "flow-chip active" : "flow-chip"}>Text extracted</span>
            <span className={fieldsExtracted ? "flow-chip active" : "flow-chip"}>Fields extracted</span>
            <span className={predictionResult ? "flow-chip active" : "flow-chip"}>Prediction done</span>
          </div>
        </section>
      </section>
    </main>
  );
}



