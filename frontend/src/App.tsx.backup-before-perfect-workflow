              <div>
                <strong>#{item.id} — {item.first_name} {item.last_name}</strong>
                <p><StatusBadge value={item.status} /></p>
              </div>

              <button className="btn secondary" onClick={() => selectApplication(item)}>
                Use
              </button>
            </div>
          ))}
        </div>
      </div>
    </AppLayout>
  );
}


function AdminReviewsPage() {
  const [pending, setPending] = useState<Application[]>([]);
  const [reviews, setReviews] = useState<Review[]>([]);
  const [notes, setNotes] = useState<Record<number, string>>({});
  const [message, setMessage] = useState("");

  const loadData = async () => {
    try {
      const [pendingResponse, reviewsResponse] = await Promise.all([
        api.get<Application[]>("/reviews/pending"),
        api.get<Review[]>("/reviews/all"),
      ]);

      setPending(pendingResponse.data);
      setReviews(reviewsResponse.data);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  useEffect(() => {
    loadData();
  }, []);

  const decide = async (applicationId: number, statusValue: string) => {
    try {
      await api.post<Review>(`/reviews/${applicationId}/decision`, {
        review_status: statusValue,
        review_note: notes[applicationId] || "",
      });

      setMessage("Review decision saved.");
      await loadData();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  return (
    <AppLayout>
      <div className="page-title">
        <div>
          <h1>Admin Reviews</h1>
          <p>Approve, reject, or request more information.</p>
        </div>
        <button className="btn secondary" onClick={loadData}>Refresh</button>
      </div>

      {message && <div className="alert info">{message}</div>}

      <div className="card">
        <h2>Pending Review Applications</h2>

        {pending.length === 0 && <p className="muted">No pending applications.</p>}

        {pending.map((item) => (
          <div className="mini-card" key={item.id}>
            <div className="row-between">
              <div>
                <strong>#{item.id} — {item.first_name} {item.last_name}</strong>
                <p>Income: {item.monthly_income ?? "-"} | Phone: {item.phone}</p>
                <StatusBadge value={item.status} />
              </div>
            </div>

            <label>Review Note</label>
            <textarea
              value={notes[item.id] || ""}
              onChange={(event) =>
                setNotes({ ...notes, [item.id]: event.target.value })
              }
              placeholder="Write review note..."
            />

            <div className="actions">
              <button className="btn success" onClick={() => decide(item.id, "approved")}>
                Approve
              </button>
              <button className="btn danger" onClick={() => decide(item.id, "rejected")}>
                Reject
              </button>
              <button className="btn warning" onClick={() => decide(item.id, "need_more_information")}>
                Need More Info
              </button>
            </div>
          </div>
        ))}
      </div>

      <div className="card">
        <h2>Review History</h2>
        <div className="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Application</th>
                <th>Status</th>
                <th>Note</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              {reviews.map((item) => (
                <tr key={item.id}>
                  <td>#{item.id}</td>
                  <td>#{item.application_id}</td>
                  <td><StatusBadge value={item.review_status} /></td>
                  <td>{item.review_note || "-"}</td>
                  <td>{formatDate(item.created_at)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </AppLayout>
  );
}

