function MLModelPage() {
  const [models, setModels] = useState<MLModel[]>([]);
  const [activeModel, setActiveModel] = useState<MLModel | null>(null);
  const [applications, setApplications] = useState<Application[]>([]);
  const [predictions, setPredictions] = useState<Prediction[]>([]);
  const [modelName, setModelName] = useState("Custom Baseline Model");
  const [version, setVersion] = useState("v1");
  const [description, setDescription] = useState("Created from frontend.");
  const [message, setMessage] = useState("");

  const loadData = async () => {
    try {
      const [modelsResponse, applicationsResponse, predictionsResponse] =
        await Promise.all([
          api.get<MLModel[]>("/ml-models/"),
          api.get<Application[]>("/applications/admin/all"),
          api.get<Prediction[]>("/predictions/admin/all"),
        ]);

      setModels(modelsResponse.data);
      setApplications(applicationsResponse.data);
      setPredictions(predictionsResponse.data);

      try {
        const activeResponse = await api.get<MLModel>("/ml-models/active");
        setActiveModel(activeResponse.data);
      } catch {
        setActiveModel(null);
      }

      setMessage("");
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  useEffect(() => {
    loadData();
  }, []);

  const createModel = async () => {
    try {
      await api.post("/ml-models/", {
        model_name: modelName,
        version,
        description,
      });

      setMessage("Model created successfully.");
      await loadData();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const deploy = async (id: number) => {
    try {
      await api.post(`/ml-models/${id}/deploy`);
      setMessage("Model deployed successfully.");
      await loadData();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const setActive = async (id: number) => {
    try {
      await api.post(`/ml-models/${id}/set-active`);
      setMessage("Model activated successfully. Apply page predictions will now use this model.");
      await loadData();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const deactivate = async (id: number) => {
    try {
      await api.post(`/ml-models/${id}/deactivate`);
      setMessage("Model deactivated.");
      await loadData();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const runPrediction = async (applicationId: number) => {
    try {
      const response = await api.post<Prediction>(
        `/predictions/applications/${applicationId}/run`
      );

      setMessage(
        `Prediction completed for application #${applicationId}: ${response.data.prediction_result}`
      );

      await loadData();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const getPredictionForApplication = (applicationId: number) => {
    return predictions.find((item) => item.application_id === applicationId);
  };

  const isApplicationReadyForPrediction = (application: Application) => {
    return Boolean(application.occupation && application.monthly_income !== null && application.monthly_income !== undefined);
  };

  return (
    <AppLayout>
      <div className="page-title">
        <div>
          <h1>ML Model</h1>
          <p>
            Manage models and run predictions using applications created from the Apply page.
          </p>
        </div>

        <button className="btn secondary" onClick={loadData}>Refresh</button>
      </div>

      {message && <div className="alert info">{message}</div>}

      <div className="grid two">
        <div className="card">
          <h2>Active Prediction Model</h2>

          {activeModel ? (
            <>
              <div className="field-row">
                <strong>Model</strong>
                <span>{activeModel.model_name}</span>
              </div>

              <div className="field-row">
                <strong>Version</strong>
                <span>{activeModel.version}</span>
              </div>

              <div className="field-row">
                <strong>Status</strong>
                <StatusBadge value={activeModel.status} />
              </div>

              <div className="field-row">
                <strong>Accuracy</strong>
                <span>{formatPercent(activeModel.accuracy)}</span>
              </div>

              <p className="muted">
                This active model is used automatically when prediction runs from Apply page or ML Model page.
              </p>
            </>
          ) : (
            <div className="alert error">
              No active model found. Deploy and activate one model before running predictions.
            </div>
          )}
        </div>

        <div className="card">
          <h2>Apply → ML Workflow</h2>

          <div className="field-row">
            <strong>1. Apply Page</strong>
            <span>Create application</span>
          </div>

          <div className="field-row">
            <strong>2. Complete Step 2</strong>
            <span>Occupation + income</span>
          </div>

          <div className="field-row">
            <strong>3. Generate PDF / Upload Docs</strong>
            <span>Document workflow</span>
          </div>

          <div className="field-row">
            <strong>4. ML Model</strong>
            <span>Run prediction</span>
          </div>

          <div className="field-row">
            <strong>5. Reviews</strong>
            <span>Admin decision</span>
          </div>
        </div>
      </div>

      <div className="card">
        <h2>Create Model</h2>

        <div className="form-grid">
          <div>
            <label>Model Name</label>
            <input value={modelName} onChange={(event) => setModelName(event.target.value)} />
          </div>

          <div>
            <label>Version</label>
            <input value={version} onChange={(event) => setVersion(event.target.value)} />
          </div>

          <div>
            <label>Description</label>
            <input value={description} onChange={(event) => setDescription(event.target.value)} />
          </div>
        </div>

        <button className="btn primary" onClick={createModel}>Create Model</button>
      </div>

      <div className="card">
        <h2>Model Registry</h2>

        <div className="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Model</th>
                <th>Status</th>
                <th>Active</th>
                <th>Accuracy</th>
                <th>F1</th>
                <th>Actions</th>
              </tr>
            </thead>

            <tbody>
              {models.map((item) => (
                <tr key={item.id}>
                  <td>#{item.id}</td>
                  <td>{item.model_name} ({item.version})</td>
                  <td><StatusBadge value={item.status} /></td>
                  <td>{item.is_active ? "Yes" : "No"}</td>
                  <td>{formatPercent(item.accuracy)}</td>
                  <td>{formatPercent(item.f1_score)}</td>
                  <td>
                    <div className="actions">
                      <button className="btn secondary" onClick={() => deploy(item.id)}>Deploy</button>
                      <button className="btn success" onClick={() => setActive(item.id)}>Set Active</button>
                      <button className="btn danger" onClick={() => deactivate(item.id)}>Deactivate</button>
                    </div>
                  </td>
                </tr>
              ))}

              {models.length === 0 && (
                <tr>
                  <td colSpan={7}>No models found.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

      <div className="card">
        <h2>Application Prediction Center</h2>
        <p className="muted">
          Applications created from the Apply page appear here. Admin can run prediction from this page too.
        </p>

        <div className="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Application</th>
                <th>Applicant</th>
                <th>Income</th>
                <th>Status</th>
                <th>ML Readiness</th>
                <th>Latest Prediction</th>
                <th>Action</th>
              </tr>
            </thead>

            <tbody>
              {applications.map((application) => {
                const latestPrediction = getPredictionForApplication(application.id);
                const ready = isApplicationReadyForPrediction(application);

                return (
                  <tr key={application.id}>
                    <td>#{application.id}</td>
                    <td>{application.first_name} {application.last_name}</td>
                    <td>{application.monthly_income ?? "-"}</td>
                    <td><StatusBadge value={application.status} /></td>
                    <td>
                      {ready ? (
                        <span className="badge badge-approved">Ready</span>
                      ) : (
                        <span className="badge badge-rejected">Step 2 incomplete</span>
                      )}
                    </td>
                    <td>
                      {latestPrediction ? (
                        <div>
                          <strong>{latestPrediction.prediction_result.replaceAll("_", " ")}</strong>
                          <br />
                          <RiskBadge value={latestPrediction.risk_level} />
                        </div>
                      ) : (
                        <span className="muted">No prediction</span>
                      )}
                    </td>
                    <td>
                      <button
                        className="btn primary"
                        disabled={!ready || !activeModel}
                        onClick={() => runPrediction(application.id)}
                      >
                        Run Prediction
                      </button>
                    </td>
                  </tr>
                );
              })}

              {applications.length === 0 && (
                <tr>
                  <td colSpan={7}>No applications found. Create an application from Apply page first.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

      <div className="card">
        <h2>Prediction History</h2>

        <div className="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Application</th>
                <th>Result</th>
                <th>Risk</th>
                <th>Confidence</th>
                <th>Reason</th>
                <th>Date</th>
              </tr>
            </thead>

            <tbody>
              {predictions.map((item) => (
                <tr key={item.id}>
                  <td>#{item.id}</td>
                  <td>#{item.application_id}</td>
                  <td>{item.prediction_result.replaceAll("_", " ")}</td>
                  <td><RiskBadge value={item.risk_level} /></td>
                  <td>{formatPercent(item.confidence_score)}</td>
                  <td>{item.reason}</td>
                  <td>{formatDate(item.created_at)}</td>
                </tr>
              ))}

              {predictions.length === 0 && (
                <tr>
                  <td colSpan={7}>No prediction history yet.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </AppLayout>
  );
}


function ReportsPage() {
  const [overview, setOverview] = useState<DashboardOverview | null>(null);
  const [statusReport, setStatusReport] = useState<StatusCount[]>([]);
  const [monthly, setMonthly] = useState<MonthlyReport[]>([]);
  const [predictionReport, setPredictionReport] = useState<PredictionReport | null>(null);
  const [reviewReport, setReviewReport] = useState<ReviewReport | null>(null);
  const [message, setMessage] = useState("");

  const loadData = async () => {
    try {
      const [
        overviewResponse,
        statusResponse,
        monthlyResponse,
        predictionResponse,
        reviewResponse,
      ] = await Promise.all([
        api.get<DashboardOverview>("/reports/overview"),
        api.get<StatusCount[]>("/reports/applications/status"),
        api.get<MonthlyReport[]>("/reports/applications/monthly"),
        api.get<PredictionReport>("/reports/predictions"),
        api.get<ReviewReport>("/reports/reviews"),
      ]);

      setOverview(overviewResponse.data);
      setStatusReport(statusResponse.data);
      setMonthly(monthlyResponse.data);
      setPredictionReport(predictionResponse.data);
      setReviewReport(reviewResponse.data);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  useEffect(() => {
    loadData();
  }, []);

  const downloadCsv = async () => {
    try {
      const response = await api.get("/reports/export/applications", {
        responseType: "blob",
      });

      const url = window.URL.createObjectURL(new Blob([response.data]));
      const link = document.createElement("a");
      link.href = url;
      link.setAttribute("download", "smartloan_applications_report.csv");
      document.body.appendChild(link);
      link.click();
      link.remove();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  return (
    <AppLayout>
      <div className="page-title">
        <div>
          <h1>Reports</h1>
          <p>Dashboard, application, review, prediction, and CSV export.</p>
        </div>

        <div className="actions">
          <button className="btn secondary" onClick={loadData}>Refresh</button>
          <button className="btn primary" onClick={downloadCsv}>Download CSV</button>
        </div>
      </div>

      {message && <div className="alert error">{message}</div>}

      <div className="stats-grid">
        <div className="stat-card"><p>Applications</p><h2>{overview?.total_applications ?? 0}</h2></div>
        <div className="stat-card"><p>Predictions</p><h2>{overview?.total_predictions ?? 0}</h2></div>
        <div className="stat-card"><p>Reviews</p><h2>{overview?.total_reviews ?? 0}</h2></div>
        <div className="stat-card"><p>Users</p><h2>{overview?.total_users ?? 0}</h2></div>
      </div>

      <div className="grid two">
        <div className="card">
          <h2>Application Status</h2>
          {statusReport.map((item) => (
            <div className="field-row" key={item.status}>
              <strong>{item.status.replaceAll("_", " ")}</strong>
              <span>{item.count}</span>
            </div>
          ))}
        </div>

        <div className="card">
          <h2>Prediction Report</h2>
          <div className="field-row"><strong>Total</strong><span>{predictionReport?.total_predictions ?? 0}</span></div>
          <div className="field-row"><strong>Low Risk</strong><span>{predictionReport?.low_risk ?? 0}</span></div>
          <div className="field-row"><strong>Medium Risk</strong><span>{predictionReport?.medium_risk ?? 0}</span></div>
          <div className="field-row"><strong>High Risk</strong><span>{predictionReport?.high_risk ?? 0}</span></div>
        </div>
      </div>

      <div className="grid two">
        <div className="card">
          <h2>Review Report</h2>
          <div className="field-row"><strong>Total</strong><span>{reviewReport?.total_reviews ?? 0}</span></div>
          <div className="field-row"><strong>Approved</strong><span>{reviewReport?.approved ?? 0}</span></div>
          <div className="field-row"><strong>Rejected</strong><span>{reviewReport?.rejected ?? 0}</span></div>
          <div className="field-row"><strong>Need More Info</strong><span>{reviewReport?.need_more_information ?? 0}</span></div>
        </div>

        <div className="card">
          <h2>Monthly Applications</h2>
          {monthly.length === 0 && <p className="muted">No monthly data yet.</p>}
          {monthly.map((item) => (
            <div className="field-row" key={item.month}>
              <strong>{item.month}</strong>
              <span>{item.total_applications}</span>
            </div>
          ))}
        </div>
      </div>
    </AppLayout>
  );
}

