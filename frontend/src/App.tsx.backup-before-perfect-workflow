          {documents.length === 0 && <p className="muted">No documents uploaded yet.</p>}

          <div className="document-list">
            {documents.map((document) => (
              <div className="mini-card row-between" key={document.id}>
                <div>
                  <strong>#{document.id} — {document.document_type.replaceAll("_", " ")}</strong>
                  <p>{document.original_file_name}</p>
