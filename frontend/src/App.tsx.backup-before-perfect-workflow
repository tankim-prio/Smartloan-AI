function ApplyPage() {
  const [stepOne, setStepOne] = useState({
    first_name: "Said",
    last_name: "Kabir",
    father_name: "Father Name",
    mother_name: "Mother Name",
    age: "25",
    phone: "01700000000",
    email: "applicant@example.com",
    address: "Dhaka, Bangladesh",
  });

  const [stepTwo, setStepTwo] = useState({
    occupation: "Software Developer",
    monthly_income: "60000",
  });

  const [application, setApplication] = useState<Application | null>(null);
  const [myApplications, setMyApplications] = useState<Application[]>([]);
  const [documents, setDocuments] = useState<ApplicationDocument[]>([]);
  const [fields, setFields] = useState<ExtractedField[]>([]);
  const [predictions, setPredictions] = useState<Prediction[]>([]);
  const [message, setMessage] = useState("");

  const [incomeDocumentType, setIncomeDocumentType] = useState("salary_certificate");
  const [identityDocumentType, setIdentityDocumentType] = useState("nid");

  const [files, setFiles] = useState<Record<string, File | null>>({
    incomeProof: null,
    identityProof: null,
    photo: null,
    loanApplication: null,
  });

  const applicationId = application?.id;

  const hasDocumentType = (type: string) => {
    return documents.some((document) => document.document_type === type);
  };

  const hasIncomeProof = hasDocumentType("salary_certificate") || hasDocumentType("tin_certificate");
  const hasIdentityProof = hasDocumentType("nid") || hasDocumentType("passport");
  const hasPhoto = hasDocumentType("photo");
  const hasGeneratedPdf = hasDocumentType("generated_pdf");
  const hasLoanApplication = hasDocumentType("loan_application");

  const isStepOneDone = Boolean(application);
  const isStepTwoDone = Boolean(application?.occupation && application?.monthly_income !== null && application?.monthly_income !== undefined);
  const isDocumentStepDone = hasIncomeProof && hasIdentityProof;
  const isPhotoStepDone = hasPhoto;
  const isReadyForPrediction = Boolean(isStepOneDone && isStepTwoDone);
  const isReadyForReview = Boolean(isStepOneDone && isStepTwoDone && hasGeneratedPdf);

  const latestPrediction = predictions[0];

  const setFile = (key: string, file: File | null) => {
    setFiles((current) => ({
      ...current,
      [key]: file,
    }));
  };

  const loadMyApplications = async () => {
    try {
      const response = await api.get<Application[]>("/applications/my");
      setMyApplications(response.data);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const loadDocuments = async (id: number) => {
    const response = await api.get<ApplicationDocument[]>(`/applications/${id}/documents`);
    setDocuments(response.data);
  };

  const loadFields = async (id: number) => {
    const response = await api.get<ExtractedField[]>(`/applications/${id}/extracted-fields`);
    setFields(response.data);
  };

  const loadPredictions = async (id: number) => {
    const response = await api.get<Prediction[]>(`/predictions/applications/${id}`);
    setPredictions(response.data);
  };

  const refreshSelectedApplication = async (id: number) => {
    try {
      const [applicationResponse] = await Promise.all([
        api.get<Application>(`/applications/${id}`),
        loadDocuments(id),
        loadFields(id).catch(() => undefined),
        loadPredictions(id).catch(() => undefined),
      ]);

      setApplication(applicationResponse.data);
      await loadMyApplications();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const selectApplication = async (item: Application) => {
    setApplication(item);
    setMessage(`Selected application #${item.id}`);
    await refreshSelectedApplication(item.id);
  };

  useEffect(() => {
    loadMyApplications();
  }, []);

  const createStepOne = async () => {
    setMessage("");

    try {
      const response = await api.post<Application>("/applications/step-1", {
        ...stepOne,
        age: Number(stepOne.age),
      });

      setApplication(response.data);
      setMessage(`Step 1 confirmed. Application #${response.data.id} created.`);
      await loadMyApplications();
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const uploadDocumentBySlot = async (
    slotKey: string,
    documentType: string,
    successMessage: string
  ) => {
    if (!applicationId) {
      setMessage("Create or select an application first.");
      return false;
    }

    const selectedFile = files[slotKey];

    if (!selectedFile) {
      setMessage("Please choose a file first.");
      return false;
    }

    const formData = new FormData();
    formData.append("file", selectedFile);

    await api.post(
      `/applications/${applicationId}/documents?document_type=${documentType}`,
      formData,
      {
        headers: {
          "Content-Type": "multipart/form-data",
        },
      }
    );

    setFile(slotKey, null);
    setMessage(successMessage);
    await loadDocuments(applicationId);

    return true;
  };

  const confirmStepTwo = async () => {
    if (!applicationId) {
      setMessage("Complete Step 1 first.");
      return;
    }

    try {
      const response = await api.patch<Application>(`/applications/${applicationId}/step-2`, {
        occupation: stepTwo.occupation,
        monthly_income: Number(stepTwo.monthly_income),
      });

      setApplication(response.data);

      if (files.incomeProof) {
        await uploadDocumentBySlot(
          "incomeProof",
          incomeDocumentType,
          "Income proof uploaded."
        );
      }

      if (files.identityProof) {
        await uploadDocumentBySlot(
          "identityProof",
          identityDocumentType,
          "Identity proof uploaded."
        );
      }

      setMessage("Step 2 confirmed. Occupation, income, and selected documents saved.");
      await refreshSelectedApplication(applicationId);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const confirmPhoto = async () => {
    if (!applicationId) {
      setMessage("Complete Step 1 first.");
      return;
    }

    try {
      if (!files.photo) {
        setMessage("Choose photo/scan file first.");
        return;
      }

      await uploadDocumentBySlot("photo", "photo", "Step 3 confirmed. Photo uploaded.");
      await refreshSelectedApplication(applicationId);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const generatePdf = async () => {
    if (!applicationId) {
      setMessage("Create or select an application first.");
      return;
    }

    try {
      const response = await api.post<ApplicationDocument>(
        `/applications/${applicationId}/generate-pdf`
      );

      setMessage(`PDF created successfully. Document ID: ${response.data.id}`);
      await refreshSelectedApplication(applicationId);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const uploadLoanApplication = async () => {
    if (!applicationId) {
      setMessage("Create or select an application first.");
      return;
    }

    try {
      await uploadDocumentBySlot(
        "loanApplication",
        "loan_application",
        "Loan application document uploaded."
      );

      await refreshSelectedApplication(applicationId);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const extractLatestPdf = async () => {
    if (!applicationId) {
      setMessage("Select application first.");
      return;
    }

    const latestPdf = documents.find((document) => document.document_type === "generated_pdf");

    if (!latestPdf) {
      setMessage("Create PDF first, then extract fields.");
      return;
    }

    try {
      await api.post(
        `/applications/${applicationId}/extract-text?document_id=${latestPdf.id}`
      );

      const response = await api.post<ExtractedField[]>(
        `/applications/${applicationId}/extract-fields`
      );

      setFields(response.data);
      setMessage("PDF text and fields extracted successfully.");
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const runPrediction = async () => {
    if (!applicationId) {
      setMessage("Select application first.");
      return;
    }

    if (!isReadyForPrediction) {
      setMessage("Complete Step 1 and Step 2 before prediction.");
      return;
    }

    try {
      const response = await api.post<Prediction>(
        `/predictions/applications/${applicationId}/run`
      );

      setMessage(`Prediction completed: ${response.data.prediction_result}`);
      await refreshSelectedApplication(applicationId);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  const sendReview = async () => {
    if (!applicationId) {
      setMessage("Select application first.");
      return;
    }

    if (!isReadyForReview) {
      setMessage("Complete Step 1, Step 2, and create PDF before sending review.");
      return;
    }

    try {
      const response = await api.post<Application>(
        `/applications/${applicationId}/send-review`
      );

      setApplication(response.data);
      setMessage("Application sent for admin review.");
      await refreshSelectedApplication(applicationId);
    } catch (error) {
      setMessage(getApiError(error));
    }
  };

  return (
